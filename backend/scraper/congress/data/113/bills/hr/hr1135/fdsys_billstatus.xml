    <summaries>
      <summary>
        <versionCode>00</versionCode>
        <actionDate>2013-03-13</actionDate>
        <actionDesc>Introduced in House</actionDesc>
        <updateDate>2013-03-26T20:42:41Z</updateDate>
        <text><![CDATA[ <p>Burdensome Data Collection Relief Act - Amends the Dodd-Frank Wall Street Reform and Consumer Protection Act to repeal the requirement that the Securities and Exchange Commission (SEC) amend certain federal regulations about executive compensation to require each issuer of securities to disclose in any filing: (1) the median of the annual total compensation of all the issuer's employees, except the chief executive officer; (2) the annual total compensation of the chief executive officer; and (3) the ratio of the first amount to the second.</p>]]></text>
      </summary>
    </summaries>
