    <summaries>
      <summary>
        <versionCode>00</versionCode>
        <actionDate>2018-06-12</actionDate>
        <actionDesc>Introduced in Senate</actionDesc>
        <updateDate>2019-01-15T17:01:16Z</updateDate>
        <text><![CDATA[ <p><b>CHIP Mental Health and Addiction Parity Act</b></p> <p>This bill requires Children's Health Insurance Program (CHIP) plans to cover&nbsp;mental health and substance-use disorder services. Financial requirements and treatment limitations applicable to&nbsp;such services shall not differ from those applicable to&nbsp;other medical services under CHIP. </p>]]></text>
      </summary>
    </summaries>
