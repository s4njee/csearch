      <summary>
        <versionCode>00</versionCode>
        <actionDate>2018-08-24</actionDate>
        <actionDesc>Introduced in House</actionDesc>
        <updateDate>2018-12-19T18:34:17Z</updateDate>
        <text><![CDATA[ <p><b>Aretha Franklin Congressional Gold Medal Act</b></p> <p>This bill instructs the Speaker of the House of Representatives and the President pro tempore of the Senate to arrange for the posthumous presentation of a Congressional Gold Medal in commemoration of Aretha Franklin in recognition of her outstanding artistic and historical significance to the culture of the United States. </p>]]></text>
      </summary>
    </summaries>
