      <summary>
        <versionCode>00</versionCode>
        <actionDate>2017-09-25</actionDate>
        <actionDesc>Introduced in House</actionDesc>
        <updateDate>2019-07-19T22:08:15Z</updateDate>
        <text><![CDATA[ <p><b>Protecting Workers and Improving Labor Standards Act</b></p> <p>This bill amends the National Labor Relations Act to allow labor agreements to require membership in a labor organization as a condition of employment regardless of state law (thus preempting state laws that prohibit such agreements).</p>]]></text>
      </summary>
