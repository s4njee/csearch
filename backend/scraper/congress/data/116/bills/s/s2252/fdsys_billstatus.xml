    <summaries>
      <summary>
        <versionCode>00</versionCode>
        <actionDate>2019-07-24</actionDate>
        <actionDesc>Introduced in Senate</actionDesc>
        <updateDate>2020-11-03T21:46:01Z</updateDate>
        <text><![CDATA[ <p><b>Empowering States to Address Drug Costs Act</b></p> <p>This bill expands the purposes for which states may use certain drug pricing information that is disclosed to them by manufacturers through the Medicaid Drug Rebate Program. Specifically, the bill allows states to use such information in furtherance of prescription drug affordability boards or state multi-payer purchasing pools.</p>]]></text>
      </summary>
    </summaries>
