      <summary>
        <versionCode>00</versionCode>
        <actionDate>2019-02-28</actionDate>
        <actionDesc>Introduced in Senate</actionDesc>
        <updateDate>2020-02-10T23:32:12Z</updateDate>
        <text><![CDATA[ <p><strong>Same Day Registration Act</strong></p> <p>This bill requires states with a voter registration requirement to make same-day voter registration available at the polling place on any day voting is permitted.</p>]]></text>
      </summary>
