      </item>
      <item>
        <titleType>Official Title as Introduced</titleType>
        <title>A bill to amend titles 10 and 18, to permit members of the Armed Forces to possess firearms on military installations in accordance with applicable State law, and for other purposes.</title>
        <billTextVersionName>Introduced in Senate</billTextVersionName>
        <billTextVersionCode>IS</billTextVersionCode>
