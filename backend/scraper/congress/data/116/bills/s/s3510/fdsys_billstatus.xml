    <summaries>
      <summary>
        <versionCode>00</versionCode>
        <actionDate>2020-03-17</actionDate>
        <actionDesc>Introduced in Senate</actionDesc>
        <updateDate>2020-04-07T18:10:29Z</updateDate>
        <text><![CDATA[ <p><strong>Prioritizing Pandemic Prevention Act</strong></p> <p>This bill transfers any unobligated federal funds for constructing a physical barrier along the U.S.-Mexico border to the Department of Health and Human Services and the U.S. Agency for International Development to combat COVID-19 (i.e., coronavirus disease 2019).</p>]]></text>
      </summary>
    </summaries>
