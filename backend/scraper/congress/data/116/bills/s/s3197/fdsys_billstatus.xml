        <billTextVersionCode>IS</billTextVersionCode>
      </item>
      <item>
        <titleType>Official Title as Introduced</titleType>
        <title>A bill to revoke or deny visas to Chinese officials involved in the formulation or execution of a policy that prevents innocent United States citizens from leaving China.</title>
        <billTextVersionName>Introduced in Senate</billTextVersionName>
        <billTextVersionCode>IS</billTextVersionCode>
      </item>
