    <summaries>
      <summary>
        <versionCode>00</versionCode>
        <actionDate>2019-06-26</actionDate>
        <actionDesc>Introduced in Senate</actionDesc>
        <updateDate>2020-03-16T14:52:56Z</updateDate>
        <text><![CDATA[ <p><b>Small Business Investment Improvement Act of 2019</b></p> <p>This bill directs the Small Business Administration to approve or decline an applicant seeking a license to operate as a small business investment company (SBIC) within certain specified timelines, and it requires an applicant to successfully pass a Federal Bureau of Investigation background check before it may become an SBIC. </p>]]></text>
      </summary>
    </summaries>
