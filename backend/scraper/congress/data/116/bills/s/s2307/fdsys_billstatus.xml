    <summaries>
      <summary>
        <versionCode>00</versionCode>
        <actionDate>2019-07-29</actionDate>
        <actionDesc>Introduced in Senate</actionDesc>
        <updateDate>2020-08-06T15:46:17Z</updateDate>
        <text><![CDATA[ <p><b>World Language Advancement and Readiness Act of 2019</b></p> <p>This bill directs the Department of Defense to award three-year competitive grants to state and local educational agencies for the establishment, improvement, or expansion of world language (e.g., foreign language or American Sign Language) programs in elementary and secondary schools.</p>]]></text>
      </summary>
    </summaries>
