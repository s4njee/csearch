    <summaries>
      <summary>
        <versionCode>00</versionCode>
        <actionDate>2020-12-17</actionDate>
        <actionDesc>Introduced in House</actionDesc>
        <updateDate>2021-08-23T14:03:17Z</updateDate>
        <text><![CDATA[ <p><b>Preserving Existing Nuclear Energy Generation Act</b></p> <p>This bill provides for the establishment of (1) a program to evaluate nuclear reactors that are projected to cease operations due to economic factors and to allocate financial credits to certain reactors, and (2) a grant program to assist communities with revenue shortfalls due to closures of nuclear power plants.</p>]]></text>
      </summary>
    </summaries>
