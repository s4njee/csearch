FROM node:24-alpine

# Install tools needed by the deploy entrypoint
RUN apk add --no-cache aws-cli bash curl kubectl tzdata

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm ci

# Copy the rest of the frontend code
COPY . .

RUN chmod +x /app/deploy-container.sh

ENTRYPOINT ["/bin/bash", "/app/deploy-container.sh"]
