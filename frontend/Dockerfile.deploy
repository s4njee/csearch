FROM node:20-alpine

# Install AWS CLI and bash
RUN apk add --no-cache aws-cli bash

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm ci

# Copy the rest of the frontend code
COPY . .

# We'll run the deployment steps directly in the cronjob, overriding CMD
# Or we can run a modified shell script if preferred.
CMD ["npm", "run", "generate"]
