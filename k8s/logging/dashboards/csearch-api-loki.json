{
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "12.3.1"
    },
    {
      "type": "datasource",
      "id": "loki",
      "name": "Loki",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "Loki",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (route) (rate({namespace=~\"$namespace\", app=~\"$app\"} | json | msg=\"request completed\" [5m]))",
          "legendFormat": "{{route}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Request Rate by Route",
      "type": "timeseries"
    },
    {
      "datasource": "Loki",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "quantile_over_time(0.50, {namespace=~\"$namespace\", app=~\"$app\"} | json | msg=\"request completed\" | unwrap responseTime [5m])",
          "legendFormat": "p50",
          "queryType": "range",
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "quantile_over_time(0.95, {namespace=~\"$namespace\", app=~\"$app\"} | json | msg=\"request completed\" | unwrap responseTime [5m])",
          "legendFormat": "p95",
          "queryType": "range",
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "quantile_over_time(0.99, {namespace=~\"$namespace\", app=~\"$app\"} | json | msg=\"request completed\" | unwrap responseTime [5m])",
          "legendFormat": "p99",
          "queryType": "range",
          "refId": "C"
        }
      ],
      "title": "Latency Percentiles",
      "type": "timeseries"
    },
    {
      "datasource": "Loki",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "green",
                "value": 90
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "100 * sum(count_over_time({namespace=~\"$namespace\", app=~\"$app\"} | json | msg=\"request completed\" | cache=\"HIT\" [5m])) / sum(count_over_time({namespace=~\"$namespace\", app=~\"$app\"} | json | msg=\"request completed\" [5m]))",
          "legendFormat": "hit-rate",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Cache Hit Rate",
      "type": "stat"
    },
    {
      "datasource": "Loki",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 80,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 16,
        "x": 8,
        "y": 8
      },
      "id": 4,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (statusCode) (count_over_time({namespace=~\"$namespace\", app=~\"$app\"} | json | msg=\"request completed\" | statusCode=~\"4..|5..\" [5m]))",
          "legendFormat": "{{statusCode}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Error Rate by Status Code",
      "type": "timeseries"
    },
    {
      "datasource": "Loki",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 13
      },
      "id": 5,
      "options": {
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "topk(10, sum by (query) (count_over_time({namespace=~\"$namespace\", app=~\"$app\"} | json | msg=\"search executed\" [1h])))",
          "instant": true,
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Top Search Queries (1h)",
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 41,
  "tags": [
    "csearch",
    "logs",
    "loki"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "selected": true,
          "text": "default",
          "value": "default"
        },
        "datasource": "Loki",
        "definition": "label_values(namespace)",
        "hide": 0,
        "includeAll": false,
        "label": "Namespace",
        "multi": false,
        "name": "namespace",
        "options": [],
        "query": {
          "query": "label_values(namespace)",
          "refId": "namespace-variable"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "current": {
          "selected": true,
          "text": "csearch-api",
          "value": "csearch-api"
        },
        "datasource": "Loki",
        "definition": "label_values(app)",
        "hide": 0,
        "includeAll": false,
        "label": "App",
        "multi": false,
        "name": "app",
        "options": [],
        "query": {
          "query": "label_values(app)",
          "refId": "app-variable"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "title": "CSearch API Logs",
  "uid": "csearch-api-logs",
  "version": 1
}
