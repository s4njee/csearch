# Copy this file to .env.prod and fill in real values.
# .env.prod is NOT committed to git.

# ── Cluster ──────────────────────────────────────────────────────────────────
CLUSTER_HOST=root@<server-ip>
KUBECTL_CONTEXT=netcup

# ── Container registry ────────────────────────────────────────────────────────
REGISTRY=registry.example.com

# ── AWS / CloudFront ──────────────────────────────────────────────────────────
S3_BUCKET=s3://your-bucket-name
CF_DIST_CSEARCH=<cloudfront-distribution-id>
CF_DIST_CONGRESS=<cloudfront-distribution-id-2>

# ── API ───────────────────────────────────────────────────────────────────────
NUXT_API_SERVER=https://api.your-domain.com
API_SECRET_KEY=<random-secret>

# ── Logging / Fluent Bit ──────────────────────────────────────────────────────
# Provide an HTTP collector endpoint before enabling the logging DaemonSet.
LOG_SHIP_HTTP_HOST=logs.your-domain.com
LOG_SHIP_HTTP_PORT=443
LOG_SHIP_HTTP_URI=/ingest

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=<strong-password>
