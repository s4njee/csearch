# Copy this file to .env.prod and fill in real values.
# .env.prod is NOT committed to git.

# ── Cluster ──────────────────────────────────────────────────────────────────
CLUSTER_HOST=root@<server-ip>
KUBECTL_CONTEXT=netcup

# ── Container registry ────────────────────────────────────────────────────────
REGISTRY=registry.example.com

# ── Cloudflare Pages ─────────────────────────────────────────────────────────
CF_PAGES_PROJECT=csearch
CF_PAGES_BRANCH=main

# ── API ───────────────────────────────────────────────────────────────────────
NUXT_API_SERVER=https://api.csearch.org
API_SECRET_KEY=<random-secret>

# ── Logging / Fluent Bit ──────────────────────────────────────────────────────
# Default mode: deploy the tiny in-cluster HTTP collector and point Fluent Bit at it.
ENABLE_TINY_LOG_COLLECTOR=true
LOG_COLLECTOR_HOSTPATH=/root/logs

# Optional direct S3 output. When LOG_S3_BUCKET is set, deploy.sh prefers this over HTTP shipping.
LOG_S3_BUCKET=
LOG_S3_REGION=us-east-1
LOG_S3_TOTAL_FILE_SIZE=50M
LOG_S3_UPLOAD_TIMEOUT=10m
LOG_S3_USE_PUT_OBJECT=Off
LOG_S3_STORE_DIR_LIMIT_SIZE=512M

# Optional static AWS credentials for Fluent Bit. Leave unset to rely on IAM/OIDC/instance role credentials.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Optional external HTTP collector override.
LOG_SHIP_HTTP_HOST=
LOG_SHIP_HTTP_PORT=
LOG_SHIP_HTTP_URI=
LOG_SHIP_HTTP_TLS=On
LOG_SHIP_HTTP_TLS_VERIFY=On

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=<strong-password>
